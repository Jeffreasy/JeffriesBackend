# --- Frontend ---
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Convex + Automation Engine ---
CONVEX_SITE_URL=https://adorable-mink-458.eu-west-1.convex.site
