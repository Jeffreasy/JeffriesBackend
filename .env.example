# ============================================================
# HOMEAPP — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_ENV=development          # development | production
# REQUIRED outside development: generate a unique random value of at least 32 characters.
APP_SECRET_KEY=change-me-to-a-long-random-secret
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
MATTER_SERVER_PORT=5580
# Number of trusted reverse-proxy hops in front of the app (for un-spoofable
# rate limiting). 0 = trust nothing / use the TCP peer. Set to 1 behind Render's edge.
TRUSTED_PROXY_COUNT=0

# --- Database (PostgreSQL) ---
DB_HOST=postgres
DB_PORT=5432
DB_PUBLISHED_PORT=15432
DB_NAME=homeapp
DB_USER=homeapp
# REQUIRED. Generate a unique value; Docker Compose refuses an empty/default password.
DB_PASSWORD=
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable
MIGRATIONS_DIR=/migrations

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Sync + Automation Engine ---
HOMEAPP_GAS_SECRET=change-me-to-a-long-random-secret
HOMEAPP_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BRIDGE_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBAPP_URL=https://jeffries-homeapp.vercel.app
AUTOMATION_ENGINE_ENABLED=false
START_BACKGROUND_ENGINE=false
TELEGRAM_BOT_ENABLED=true
LIGHT_COMMAND_MODE=direct
ENGINE_CRONS_ENABLED=true
ENGINE_AUTOMATIONS_ENABLED=true
ENGINE_COMMAND_POLLER_ENABLED=true
ENGINE_STATUS_POLL_ENABLED=true
GMAIL_SYNC_ENABLED=false
GOOGLE_CALENDAR_SYNC_ENABLED=false
TODOIST_SYNC_ENABLED=false
API_RATE_LIMIT_RPS=12
API_RATE_LIMIT_BURST=40

# --- LAN bridge (only required for LIGHT_COMMAND_MODE=queue / cloud bridge mode) ---
# BRIDGE_API_KEY must be a unique random value of at least 32 characters,
# identical on cloud API and local bridge, and NEVER equal to APP_SECRET_KEY.
BRIDGE_API_URL=
BRIDGE_API_KEY=
BRIDGE_STATUS_POLL_ENABLED=true
BRIDGE_RATE_LIMIT_RPS=20
BRIDGE_RATE_LIMIT_BURST=80

# --- Google OAuth (Gmail + Calendar sync) ---
# Generate GOOGLE_REFRESH_TOKEN with:
#   node scripts/gen-gmail-token.mjs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
SDB_CALENDAR_ID=7gml08968kada988va91mu3i2qkci0ts@import.calendar.google.com
GOOGLE_PERSONAL_CALENDAR_IDS=

# --- AI + Telegram voice ---
GROK_API_KEY=
GROK_MODEL=grok-4.3
GROK_REASONING_EFFORT=low
# Optional price per 1M tokens for AI cost estimation in /settings/ai/diagnostics.
# Leave 0 to track tokens only (no euro/dollar estimate).
GROK_PRICE_INPUT_PER_MTOK=0
GROK_PRICE_OUTPUT_PER_MTOK=0
GROQ_API_KEY=

# --- Todoist ---
TODOIST_API_TOKEN=
TODOIST_PROJECT_ID=

# --- bunq (LaventeCare offertes, uren en facturen) ---
# Interne offerte/uren/factuur-workflows werken zonder bunq.
# Live betaalverzoeken vereisen API-key, user-id en monetary-account-id.
BUNQ_ENVIRONMENT=sandbox
BUNQ_API_KEY=
BUNQ_USER_ID=
BUNQ_MONETARY_ACCOUNT_ID=
BUNQ_DEVICE_DESCRIPTION=JeffriesHomeapp Render

# --- LaventeCare mailbox (templated mails via Microsoft Graph) ---
# Vereist een Microsoft Entra app met application permissions: Mail.Send.
# Inbound mailbox-sync kan later dezelfde tenant/client gebruiken.
LAVENTECARE_MAIL_ENABLED=false
LAVENTECARE_MAIL_PROVIDER=microsoft_graph
LAVENTECARE_MAIL_FROM_NAME=LaventeCare
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_SENDER_EMAIL=

# --- LaventeCare secrets ---
# REQUIRED outside development. Generate an independent random value of at least
# 32 characters; never reuse APP_SECRET_KEY, BRIDGE_API_KEY or the intake secret.
LAVENTECARE_SECRET_KEY=
# Optional dedicated Bearer secret for POST /api/v1/laventecare/intake.
# Empty = endpoint fails closed. When enabled: unique, random, at least 32 chars.
LAVENTECARE_INTAKE_SECRET=

# --- Render + local LAN bridge voorbeeld ---
# Render API/background engine:
# START_BACKGROUND_ENGINE=true
# LIGHT_COMMAND_MODE=queue
# ENGINE_CRONS_ENABLED=true
# ENGINE_AUTOMATIONS_ENABLED=true
# ENGINE_COMMAND_POLLER_ENABLED=false
# TELEGRAM_BOT_TOKEN=<bot token>
# TELEGRAM_CHAT_ID=<jouw chat id>
# TELEGRAM_WEBAPP_URL=https://jeffries-homeapp.vercel.app
#
# Lokale pc bridge richting Render API:
# BRIDGE_API_URL=https://jeffriesbackend.onrender.com/api/v1
# BRIDGE_API_KEY=<dezelfde bridge-only waarde als BRIDGE_API_KEY op Render; nooit APP_SECRET_KEY>
# BRIDGE_STATUS_POLL_ENABLED=true
# ENGINE_CRONS_ENABLED=false
# ENGINE_AUTOMATIONS_ENABLED=false
# TELEGRAM_BOT_ENABLED=false

# --- Logging ---
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
