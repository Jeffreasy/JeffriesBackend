# ============================================================
# HOMEAPP — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_ENV=development          # development | production
APP_SECRET_KEY=change-me-to-a-long-random-secret
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database (PostgreSQL) ---
DB_HOST=postgres
DB_PORT=5432
DB_PUBLISHED_PORT=15432
DB_NAME=homeapp
DB_USER=homeapp
DB_PASSWORD=change-me
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable
MIGRATIONS_DIR=/migrations

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Sync + Automation Engine ---
HOMEAPP_GAS_SECRET=change-me-to-a-long-random-secret
HOMEAPP_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BRIDGE_SECRET=
AUTOMATION_ENGINE_ENABLED=false
START_BACKGROUND_ENGINE=false
TELEGRAM_BOT_ENABLED=true
LIGHT_COMMAND_MODE=direct
ENGINE_CRONS_ENABLED=true
ENGINE_AUTOMATIONS_ENABLED=true
ENGINE_COMMAND_POLLER_ENABLED=true
ENGINE_STATUS_POLL_ENABLED=true
GMAIL_SYNC_ENABLED=false
GOOGLE_CALENDAR_SYNC_ENABLED=false
TODOIST_SYNC_ENABLED=false
API_RATE_LIMIT_RPS=12
API_RATE_LIMIT_BURST=40

# --- Render + local LAN bridge voorbeeld ---
# Render API/background engine:
# START_BACKGROUND_ENGINE=true
# LIGHT_COMMAND_MODE=queue
# ENGINE_CRONS_ENABLED=true
# ENGINE_AUTOMATIONS_ENABLED=true
# ENGINE_COMMAND_POLLER_ENABLED=false
#
# Lokale pc bridge richting Render Postgres:
# DATABASE_URL=<Render external Postgres URL>
# LIGHT_COMMAND_MODE=direct
# ENGINE_CRONS_ENABLED=false
# ENGINE_AUTOMATIONS_ENABLED=false
# ENGINE_COMMAND_POLLER_ENABLED=true
# ENGINE_STATUS_POLL_ENABLED=true
# TELEGRAM_BOT_ENABLED=false

# --- Logging ---
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
