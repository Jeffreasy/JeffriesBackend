# ============================================================
# HOMEAPP — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_ENV=development          # development | production
APP_SECRET_KEY=change-me-to-a-long-random-secret
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database (PostgreSQL) ---
DB_HOST=postgres
DB_PORT=5432
DB_PUBLISHED_PORT=15432
DB_NAME=homeapp
DB_USER=homeapp
DB_PASSWORD=change-me
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=disable
MIGRATIONS_DIR=/migrations

# --- Frontend ---
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Sync + Automation Engine ---
HOMEAPP_GAS_SECRET=change-me-to-a-long-random-secret
HOMEAPP_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BRIDGE_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBAPP_URL=https://jeffrieshomeapp.com
AUTOMATION_ENGINE_ENABLED=false
START_BACKGROUND_ENGINE=false
TELEGRAM_BOT_ENABLED=true
LIGHT_COMMAND_MODE=direct
ENGINE_CRONS_ENABLED=true
ENGINE_AUTOMATIONS_ENABLED=true
ENGINE_COMMAND_POLLER_ENABLED=true
ENGINE_STATUS_POLL_ENABLED=true
GMAIL_SYNC_ENABLED=false
GOOGLE_CALENDAR_SYNC_ENABLED=false
TODOIST_SYNC_ENABLED=false
API_RATE_LIMIT_RPS=12
API_RATE_LIMIT_BURST=40

# --- Google OAuth (Gmail + Calendar sync) ---
# Generate GOOGLE_REFRESH_TOKEN with:
#   node scripts/gen-gmail-token.mjs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
SDB_CALENDAR_ID=7gml08968kada988va91mu3i2qkci0ts@import.calendar.google.com
GOOGLE_PERSONAL_CALENDAR_IDS=

# --- AI + Telegram voice ---
GROK_API_KEY=
GROK_MODEL=grok-4.3
GROK_REASONING_EFFORT=low
GROQ_API_KEY=

# --- Todoist ---
TODOIST_API_TOKEN=
TODOIST_PROJECT_ID=

# --- bunq (LaventeCare offertes, uren en facturen) ---
# Interne offerte/uren/factuur-workflows werken zonder bunq.
# Live betaalverzoeken vereisen API-key, user-id en monetary-account-id.
BUNQ_ENVIRONMENT=sandbox
BUNQ_API_KEY=
BUNQ_USER_ID=
BUNQ_MONETARY_ACCOUNT_ID=
BUNQ_CALLBACK_SECRET=
BUNQ_DEVICE_DESCRIPTION=JeffriesHomeapp Render

# --- LaventeCare mailbox (templated mails via Microsoft Graph) ---
# Vereist een Microsoft Entra app met application permissions: Mail.Send.
# Inbound mailbox-sync kan later dezelfde tenant/client gebruiken.
LAVENTECARE_MAIL_ENABLED=false
LAVENTECARE_MAIL_PROVIDER=microsoft_graph
LAVENTECARE_MAIL_FROM_NAME=LaventeCare
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_SENDER_EMAIL=

# --- Render + local LAN bridge voorbeeld ---
# Render API/background engine:
# START_BACKGROUND_ENGINE=true
# LIGHT_COMMAND_MODE=queue
# ENGINE_CRONS_ENABLED=true
# ENGINE_AUTOMATIONS_ENABLED=true
# ENGINE_COMMAND_POLLER_ENABLED=false
# TELEGRAM_BOT_TOKEN=<bot token>
# TELEGRAM_CHAT_ID=<jouw chat id>
# TELEGRAM_WEBAPP_URL=https://jeffrieshomeapp.com
#
# Lokale pc bridge richting Render API:
# BRIDGE_API_URL=https://jeffriesbackend.onrender.com/api/v1
# BRIDGE_API_KEY=<zelfde waarde als APP_SECRET_KEY op Render>
# BRIDGE_STATUS_POLL_ENABLED=true
# ENGINE_CRONS_ENABLED=false
# ENGINE_AUTOMATIONS_ENABLED=false
# TELEGRAM_BOT_ENABLED=false

# --- Logging ---
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
